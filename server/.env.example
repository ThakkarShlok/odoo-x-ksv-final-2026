# Copy this file to server/.env and fill in real values.
#   Windows PowerShell:  Copy-Item server\.env.example server\.env
# server/.env is gitignored and must NEVER be committed.

# Local PostgreSQL 18. No pooler, no directUrl: a local instance is a direct TCP
# connection, so there is no pooled/direct split to declare. directUrl exists for
# serverless setups (e.g. PgBouncer/Neon) where migrations must bypass the pooler.
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/transitops_dev"

# Signing key for JWTs. Generate a real one, do not ship "replace-me":
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-me"

PORT=5000
NODE_ENV=development

# CORS allowlist — the exact Vite dev origin. Not "*": credentials-bearing
# requests must come from a known origin.
CLIENT_ORIGIN=http://localhost:5173

# Rate limiting for /api/auth (15 min window). MAX is deliberately high for a
# hackathon demo so live testing never locks the team out; lower it for production.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
