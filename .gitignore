# Dependencies
node_modules/

# Environment — real secrets never enter git.
# .env.example IS tracked (see negation below) because it is the setup contract.
.env
.env.*
!.env.example

# Builds
dist/
build/
client/dist/

# Uploaded & seed-generated images — the BYTES are never tracked: uploaded files are user data,
# and seed images are regenerated deterministically by `npm run db:seed`. Only the .gitkeep is
# tracked so the directory exists on a fresh clone (multer requires the destination to exist).
server/uploads/*
!server/uploads/.gitkeep

# Logs
logs/
*.log
npm-debug.log*

# Test / coverage
coverage/
.vitest/

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Editors
.vscode/
.idea/
*.swp

# Explicitly NOT ignored (documented so nobody "helpfully" adds them):
#   server/prisma/schema.prisma  — the schema is the source of truth
#   server/prisma/migrations/    — migration history must be shared or the team diverges
#   docs/                        — the frozen API contract lives here
#   *.md                         — README, docs/*.md, schema-decisions are review artifacts;
#                                  never ignore them (a `*.md` ignore was removed on purpose)