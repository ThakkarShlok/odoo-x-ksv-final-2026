# Copy this file to client/.env
#   PowerShell:  Copy-Item client\.env.example client\.env

# Vite inlines VITE_* variables into the built JS bundle at build time.
# They are therefore PUBLIC — anyone can read them in devtools.
# Never put a secret here. This is a URL, which is fine; an API key would not be.
VITE_API_BASE_URL=http://localhost:5000/api
